# Frameworks GitHub Webhook Relay configuration
# Copy this file to config.env and fill in the values marked <REQUIRED>

# ---- Secrets ----

# GitHub Webhook Secret (set when creating the webhook in repo settings)
GITHUB_WEBHOOK_SECRET=<REQUIRED>

# GitHub Personal Access Token (classic, repo+workflow+read:org scopes)
# NOTE: Fine-grained PATs cannot grant write access on org repos you don't own.
#       Use a classic PAT for the fork workflow on org repositories.
GITHUB_TOKEN=<REQUIRED>

# ---- Identity ----

# The repository this relay serves (full_name format)
ALLOWED_REPO=security-alliance/frameworks

# Bot's own GitHub username -- events from this user are ignored (self-event filter)
BOT_USERNAME=<REQUIRED>

# Whitelisted GitHub usernames who can trigger actions (comma-separated, case-insensitive)
ALLOWED_SENDERS=<REQUIRED>

# ---- Models ----

# Model fallback chain: tried in order until one succeeds.
# If rate-limited (429) or the model fails, the relay falls back to the next.
# Format: provider/model, comma-separated
# Pick models that: (1) support tool use, (2) are available on your provider,
# (3) have enough context for code review. The first model is the primary.
# Example: openrouter/your-primary-model,openrouter/your-fallback-model
MODEL_CHAIN=<REQUIRED>

# Self-review models (when reviewing bot's own PRs).
# Use alternate models to avoid reviewing your own code with the model that wrote it.
# Format: same as MODEL_CHAIN
# Example: openrouter/your-alt-model
SELF_REVIEW_MODELS=<REQUIRED>

# ---- Paths ----

# Hermes chat binary path
HERMES_BIN=/home/REPLACE_ME/.local/bin/hermes

# Repo local path
REPO_PATH=/home/REPLACE_ME/frameworks

# Relay listen port
RELAY_PORT=9191

# ---- Relay internals ----

# Deduplication: path to seen-delivery-IDs database (SQLite)
DELIVERY_DB=/home/REPLACE_ME/ops/frameworks-gh-relay/deliveries.db

# Log file
LOG_FILE=/home/REPLACE_ME/ops/frameworks-gh-relay/relay.log

# Dangerous command audit log (auto-denied commands are recorded here)
DANGEROUS_CMD_LOG=/home/REPLACE_ME/ops/frameworks-gh-relay/dangerous_cmds.log

# Seconds with no output before stuck detection triggers and rescue spawns
STUCK_TIMEOUT=180

# Max parallel Hermes processes
MAX_CONCURRENT=3

# Hard kill timeout per spawn (seconds)
MAX_SPAWN_SECONDS=900
